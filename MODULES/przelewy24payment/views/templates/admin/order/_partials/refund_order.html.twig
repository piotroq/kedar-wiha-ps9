<div class="panel card">
  <div class="panel-heading card-header">
    <i class="icon-money"></i>
    {{ 'Przelewy24 - Refunds'|trans({}, 'Modules.Przelewy24payment.Order') }}
  </div>
  <div class="panel-body {% if is_177 %}card-body{% endif %}">
    <div>
      <p>
        {{ 'Here you can send returns to customers. The returned amount cannot exceed the value of the order and free funds in your account.'|trans({}, 'Modules.Przelewy24payment.Order') }}
      </p>
      <p>{{ 'Max amout to refund'|trans({}, 'Modules.Przelewy24payment.Order') }}: <span class="badge badge-info">{{ allowedRefund }}</span></p>
    </div>
    <div class="przelewy24-refund-form js-przelewy24-order-returns" data-success-message="{{ 'Refund successfully added'|trans({}, 'Modules.Przelewy24payment.Order') }}">
      {{ form_start(form) }}
      {{ form_widget(form) }}
      {{ form_end(form) }}
    </div>
  </div>
</div>


