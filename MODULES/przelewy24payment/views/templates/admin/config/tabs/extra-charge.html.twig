{{ form_start(form) }}
    {{ form_errors(form) }}

    <div class="card przelewy24-card">
        <div class="js-przelewy24-tabs-content-form-content">
            {% include '@Modules/przelewy24payment/views/templates/admin/config/form_card.html.twig' with {
                form: form,
                title: title,
                header_card: '<p><b>' ~
                'Settings for additional fees on Przelewy24 payments. '|trans({}, 'Modules.Przelewy24payment.Config')  ~ '</b></br>' ~
                'You can charge a fixed or percentage fee on orders paid via Przelewy24. If both are set, only the higher fee will be applied. The customer will be informed about this on the payment page. Enter 0 to disable the additional fee.'|trans({}, 'Modules.Przelewy24payment.Config')
                ~ '</p>',
                alert_type: 'info',
            } %}
        </div>
        <div class="card-footer przelewy24-card-footer">
            <div class="row">
                <div class="col-auto ml-auto">
                    <button class="btn-save btn btn-primary float-right">
                        {{ 'Save'|trans({}, 'Admin.Actions') }}
                    </button>
                </div>
            </div>
        </div>
    </div>
{{ form_end(form) }}
