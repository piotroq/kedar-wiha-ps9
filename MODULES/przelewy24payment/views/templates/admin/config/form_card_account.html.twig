<div class="card-header p-3">
    {% if title is defined and title is not empty %}
        <h3 class="card-title">
            {{ title }}
        </h3>
    {% endif %}
    {% if subtitle is defined and subtitle is not empty %}
        <p class="card-subtitle mt-1 font-weight-normal">
            {{ subtitle }}
        </p>
    {% endif %}
</div>

<div class="card-body {% if card_body_extra_classes is defined and card_body_extra_classes is not empty %}{{ card_body_extra_classes }}{% endif %}">
    <div class="alert alert-info">
        <p>
            {{ 'Select the currency for which you want to configure the merchant settings.'|trans({}, 'Modules.Przelewy24payment.Config') }}</br>
        {{ 'You need to configure the settings separately for each selected currency.'|trans({}, 'Modules.Przelewy24payment.Config') }}</p>
    </div>
    <div class="form-wrapper">
        {{ form_widget(form) }}
        {{ form_rest(form) }}

        {% if extra_content is defined %}
            {{ extra_content|raw }}
        {% endif %}
    </div>
</div>
