{% block payment_method_row %}
    {% if
        form.children.specialName is defined and
        form.children.specialName.vars is defined and
        form.children.specialName.vars is not empty
    %}
        {% set inputData =  form.children.specialName.vars %}
    {% endif %}

    {% if inputData is defined and inputData is not empty %}
        {% set input %}
            <input
                type="text"
                id="{{ inputData.id }}"
                name="{{ inputData.full_name }}"
                {% if inputData.required %}
                    required="required"
                {% endif %}
                class="przelewy24-payments__input-name form-control"
                value="{{ inputData.value }}"
            >
        {% endset %}

        {% include '@Modules/przelewy24payment/views/templates/admin/form_theme/_partials/payment_method.html.twig' with {
            paymentMethod: form.vars.value,
            hideName: true,
            extraContent: input
        } %}
    {% endif %}
{% endblock %}
